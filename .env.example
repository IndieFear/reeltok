# ── Production (Coolify) ─────────────────────────────────────
DASHBOARD_URL=https://reeltok.tondomaine.com
API_URL=https://api.reeltok.tondomaine.com

# ── Sécurité (obligatoire en prod) ───────────────────────────
APP_PASSWORD=choisis-un-mot-de-passe-fort
AUTH_SECRET=genere-une-chaine-aleatoire-longue
AUTH_REQUIRED=true
# COOKIE_DOMAIN=.tondomaine.com  # optionnel, auto-détecté depuis DASHBOARD_URL

# ── Clés API ─────────────────────────────────────────────────
GEMINI_API_KEY=
RUNWARE_API_KEY=
REPLICATE_API_TOKEN=
UPLOAD_POST_API_KEY=
UPLOAD_POST_USER=

# ── Optionnel ────────────────────────────────────────────────
FONT_SCALE=1.0
CAROUSEL_RENDER_CONCURRENCY=1
