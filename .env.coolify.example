# ── URLs (2 domaines dans Coolify) ──────────────────────────
# Dashboard : FQDN du service "dashboard"  (ex. https://reeltok.tondomaine.com)
DASHBOARD_URL=https://reeltok.tondomaine.com

# Backend   : FQDN du service "backend"    (ex. https://api.reeltok.tondomaine.com)
API_URL=https://api.reeltok.tondomaine.com

# ── Clés API backend ──────────────────────────────────────────
GEMINI_API_KEY=
RUNWARE_API_KEY=
REPLICATE_API_TOKEN=
UPLOAD_POST_API_KEY=
UPLOAD_POST_USER=

# ── Optionnel ───────────────────────────────────────────────
FONT_SCALE=1.0
CAROUSEL_RENDER_CONCURRENCY=1
